{
  "name": "@ttalkkak-lab/opencode-contexty",
  "version": "0.1.1-beta.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "OpenCode Plugin for Vibe Engineering with HSCMM and AASM",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opencode-contexty": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "opencode.json",
    "README.md",
    "schema.json"
  ],
  "keywords": [
    "opencode",
    "plugin",
    "context-management",
    "hscmm",
    "aasm",
    "vibe-engineering"
  ],
  "author": "Korea ttalkkak Lab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ttalkkak-lab/opencode-contexty.git"
  },
  "bugs": {
    "url": "https://github.com/ttalkkak-lab/opencode-contexty/issues"
  },
  "homepage": "https://github.com/ttalkkak-lab/opencode-contexty#readme",
  "type": "module",
  "scripts": {
    "build": "bun run tsc",
    "dev": "tsc --watch",
    "test": "bun test",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "bun run build"
  },
  "packageManager": "bun@1.0.0",
  "dependencies": {
    "@opencode-ai/plugin": "latest"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
