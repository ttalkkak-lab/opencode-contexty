{
  "name": "@ttalkkak-lab/opencode-contexty",
  "version": "0.2.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "OpenCode plugin for Contexty workflows with HSCMM, AASM, ACPM, TLS, and DCP",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opencode-contexty": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "opencode.json",
    "README.md",
    "schema.json"
  ],
  "keywords": [
    "opencode",
    "plugin",
    "context-management",
    "hscmm",
    "aasm",
    "vibe-engineering"
  ],
  "author": "Korea ttalkkak Lab",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ttalkkak-lab/opencode-contexty.git"
  },
  "bugs": {
    "url": "https://github.com/ttalkkak-lab/opencode-contexty/issues"
  },
  "homepage": "https://github.com/ttalkkak-lab/opencode-contexty#readme",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "lint": "node scripts/lint.mjs",
    "deadcode": "tsc -p tsconfig.check.json --noEmit",
    "check": "bun run typecheck && bun run lint && bun test && bun run deadcode",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "bun run build"
  },
  "packageManager": "bun@1.0.0",
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@opencode-ai/sdk": "^1.3.2"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.2.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.2",
    "bun-types": "^1.3.6",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
